# Supabase Configuration (Optional - Frontend works without these)
# You can leave these empty to run the frontend without a backend
# When these variables are not set, the app will still load but admin features and form submissions will be disabled

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# The frontend is designed to gracefully degrade when Supabase is not configured:
# - Public pages (Home, About, Programs, etc.) will display static content
# - Admin features (/admin) will show configuration messages
# - Form submissions (Contact, Admissions) will display helpful error messages
# - No errors will be thrown, the app remains fully functional
